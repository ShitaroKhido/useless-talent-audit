# ─── Dev vs Production ─────────────────────────────────────────────────────────
# Set to true to use the localStorage mock (no Firebase needed).
# .env.development already sets this to true automatically.
# Set to false (or omit) for a production build that talks to real Firebase.
VITE_USE_MOCK=false

# ─── Firebase project config ────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── App ────────────────────────────────────────────────────────────────────────
# Firestore namespace — change if you want isolated data per environment
VITE_APP_ID=useless-talent-audit

# Optional: pre-authenticate with a custom token instead of anonymous auth
VITE_INITIAL_AUTH_TOKEN=
